# SQLite database URL (WAL enabled at runtime)
CLIPSCORE_DB_URL=sqlite:///clipscore.db
# Ingestion poll interval, minutes
CLIPSCORE_POLL_INTERVAL_MINUTES=45
# Consecutive missed polls before a campaign is marked ended
CLIPSCORE_UNSEEN_POLLS_TO_END=3
# Minimum campaigns in a poll to be considered a healthy harvest
CLIPSCORE_HARVEST_MIN_CAMPAIGNS=50
# Scoring constants
CLIPSCORE_DEFAULT_P_APPROVAL=0.7
CLIPSCORE_DEFAULT_ASSUMED_CAP_USD=500
CLIPSCORE_HOURS_PER_CLIP=0.75
# Discord (later stages)
CLIPSCORE_DISCORD_TOKEN=
# Feature flags
CLIPSCORE_ENABLE_PLAYWRIGHT=false
# Pipeline B — clip-source extraction (Stage B1)
# LLM extractor (optional; unset = regex-only floor, no LLM calls)
# Provider-agnostic OpenAI-compatible chat/completions client (Stage B3) --
# defaults target OpenRouter; point elsewhere (Kimi/DeepSeek/local) by config alone.
CLIPSCORE_LLM_API_KEY=
CLIPSCORE_LLM_BASE_URL=https://openrouter.ai/api/v1
CLIPSCORE_LLM_MODEL=moonshotai/kimi-k2
# Enrich target/spec fields from the Whop product page (not just ingested description)
CLIPSCORE_EXTRACT_FROM_WHOP_PAGE=true
# Master switch for the post-ingest extraction step
CLIPSCORE_EXTRACT_ENABLED=true
# Modest pacing (seconds) between real Whop page fetches during a sweep
CLIPSCORE_WHOP_FETCH_PACING_S=1.0
# Pipeline B — clip factory (Stage B3): clipping engine
# FakeClipEngine (no network) for tests; "vizard" uses the real Vizard API.
CLIPSCORE_CLIP_ENGINE=vizard
CLIPSCORE_VIZARD_API_KEY=
